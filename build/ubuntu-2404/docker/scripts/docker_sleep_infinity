#!/bin/bash

# Get container_id from the first command-line argument
container_id="$1"

# Check if container_id is provided
if [ -z "$container_id" ]; then
    echo "Error: Container ID must be provided as the first argument."
    exit 1
fi

# Copy static binaries into the container
docker cp /usr/local/bin/bash-static    "$container_id:/bin/bash"
docker cp /usr/local/bin/bash-static    "$container_id:/bin/sh"
docker cp /usr/local/bin/busybox-static "$container_id:/bin/busybox"
docker cp /usr/local/bin/handy-sshd     "$container_id:/bin/sshd"

# Stop the container
docker stop "$container_id"

# Inspect the container to determine the binary to overwrite
# Requires jq to be installed for JSON parsing
entrypoint_json=$(docker inspect --format '{{json .Config.Entrypoint}}' "$container_id")

if ! command -v jq >/dev/null 2>&1; then
    echo "Error: jq is required for JSON parsing. Please install jq."
    exit 1
fi

if [ "$(echo "$entrypoint_json" | jq 'length')" -gt 0 ]; then
    overwrite_bin=$(echo "$entrypoint_json" | jq -r '.[0]')
else
    cmd_json=$(docker inspect --format '{{json .Config.Cmd}}' "$container_id")
    if [ "$(echo "$cmd_json" | jq 'length')" -gt 0 ]; then
        overwrite_bin=$(echo "$cmd_json" | jq -r '.[0]')
    else
        echo "Error: No Entrypoint or Cmd defined in the container."
        exit 1
    fi
fi

# Backup the original binary locally
local_backup="${container_id}.$(basename "$overwrite_bin")"
docker cp "$container_id:$overwrite_bin" "$local_backup"

# Function to restore the original binary and clean up
restore() {
    echo "Restoring original binary..."
    docker stop "$container_id" >/dev/null 2>&1 || true
    docker cp "$local_backup" "$container_id:$overwrite_bin" || true
    docker start "$container_id" >/dev/null 2>&1 || true
    # Optional: Clean up local backup
    # rm "$local_backup"
}

# Trap signals to ensure restore runs on exit
trap restore EXIT INT TERM

# Copy sleep_infinity to overwrite the determined binary
docker cp /usr/local/bin/sleep_infinity "$container_id:$overwrite_bin"

# Start the container
docker start "$container_id"

# Wait for user input to stop and restore
echo "Container started. Press Enter to stop the container and restore the original binary..."
read -r

# Explicitly call restore (though trap will handle it on exit)
restore

# Remove the trap after restore
trap - EXIT INT TERM